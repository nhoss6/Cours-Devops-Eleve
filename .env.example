# Variables d'environnement pour TrainShop
# ==================================================
# Configuration pour faire tourner l'application localement SANS Docker
# (Etape 1 du TP : verifier que le code fonctionne avant de le containeriser)

# Base de donnees PostgreSQL
# Si DATABASE_URL n'est pas defini, les variables individuelles sont utilisees
DATABASE_URL=postgresql://trainer:trainshop_dev@localhost:5432/trainshop

# OU variables individuelles (alternative a DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=trainer
DB_PASSWORD=trainshop_dev
DB_NAME=trainshop

# Cache Redis
REDIS_URL=redis://localhost:6379

# API Server
API_PORT=3000
NODE_ENV=development
